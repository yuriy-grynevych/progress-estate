generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EMPLOYEE
}

// ──────────────────────────────────────────────
// ADMIN USERS
// ──────────────────────────────────────────────
model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password       String
  name           String?
  phone          String?
  photoUrl       String?
  agentToken     String   @unique @default(cuid())
  telegramChatId String?
  role           UserRole @default(EMPLOYEE)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignedProperties Property[]
  referredInquiries  Inquiry[]  @relation("ReferredBy")
  contacts           Contact[]
  sentMessages       ChatMessage[]

  @@map("users")
}

enum ContactType {
  CLIENT
  OWNER
}

model Contact {
  id             String      @id @default(cuid())
  type           ContactType
  name           String
  phone          String?
  email          String?
  notes          String?
  source         String?
  assignedUserId String?
  assignedUser   User?       @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  properties     Property[]
  followUpAt     DateTime?
  followUpSent   Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([type])
  @@index([assignedUserId])
  @@map("contacts")
}

// ──────────────────────────────────────────────
// PROPERTIES
// ──────────────────────────────────────────────
model Property {
  id            String        @id @default(cuid())
  slug          String        @unique
  titleUk       String
  titleEn       String
  descriptionUk String        @default("")
  descriptionEn String        @default("")
  type          PropertyType
  listingType   ListingType
  status        ListingStatus @default(ACTIVE)
  price         Decimal       @db.Decimal(12, 2)
  currency      String        @default("UAH")
  areaSqm       Float
  landAreaSqm   Float?
  rooms         Int?
  bedrooms      Int?
  bathrooms     Int?
  floor         Int?
  totalFloors   Int?
  yearBuilt     Int?
  kitchenSqm    Float?
  gasType       String?
  renovationType String?
  wallType      String?
  houseNumber   String?
  city          String        @default("Івано-Франківськ")
  district      String?
  address       String?
  latitude      Float?
  longitude     Float?
  features      String[]
  isFeatured    Boolean       @default(false)
  viewCount     Int           @default(0)
  metaTitleUk   String?
  metaTitleEn   String?
  metaDescUk    String?
  metaDescEn    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  assignedUserId  String?
  assignedUser    User?    @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)

  ownerContactId  String?
  ownerContact    Contact? @relation(fields: [ownerContactId], references: [id], onDelete: SetNull)

  images    PropertyImage[]
  inquiries Inquiry[]
  auditLogs PropertyAuditLog[]

  @@index([listingType, status])
  @@index([type, status])
  @@index([city])
  @@map("properties")
}

enum PropertyType {
  APARTMENT
  HOUSE
  COMMERCIAL
  LAND
  OFFICE
}

enum ListingType {
  SALE
  RENT
}

enum ListingStatus {
  ACTIVE
  INACTIVE
  SOLD
  RENTED
}

// ──────────────────────────────────────────────
// PROPERTY IMAGES
// ──────────────────────────────────────────────
model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  altText    String?
  order      Int      @default(0)
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_images")
}

// ──────────────────────────────────────────────
// CONTACT INQUIRIES
// ──────────────────────────────────────────────
model Inquiry {
  id         String        @id @default(cuid())
  propertyId String?
  name       String
  email      String
  phone      String?
  message    String
  status     InquiryStatus @default(NEW)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  source           String?
  chatHistory      Json?

  referredByUserId String?
  referredBy       User?   @relation("ReferredBy", fields: [referredByUserId], references: [id], onDelete: SetNull)
  property         Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("inquiries")
}

enum InquiryStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

// ──────────────────────────────────────────────
// PROPERTY FEATURES (managed by admin)
// ──────────────────────────────────────────────
model Feature {
  id       String @id @default(cuid())
  value    String @unique
  labelUk  String
  labelEn  String
  order    Int    @default(0)

  @@map("features")
}

// ──────────────────────────────────────────────
// PROPERTY AUDIT LOG
// ──────────────────────────────────────────────
model PropertyAuditLog {
  id         String   @id @default(cuid())
  propertyId String
  userId     String
  userName   String
  changes    Json
  createdAt  DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_audit_logs")
}

// ──────────────────────────────────────────────
// DISTRICTS (managed by admin)
// ──────────────────────────────────────────────
model District {
  id      String @id @default(cuid())
  value   String @unique
  labelUk String
  labelEn String
  order   Int    @default(0)

  @@map("districts")
}

// ──────────────────────────────────────────────
// INTERNAL CHAT
// ──────────────────────────────────────────────
model ChatMessage {
  id            String   @id @default(cuid())
  senderId      String
  sender        User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content       String
  type          String   @default("text") // "text" | "file" | "property"
  fileUrl       String?
  fileName      String?
  propertySlug  String?
  propertyTitle String?
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@map("chat_messages")
}

// ──────────────────────────────────────────────
// TESTIMONIALS
// ──────────────────────────────────────────────
model Testimonial {
  id          String   @id @default(cuid())
  authorName  String
  authorRole  String?
  contentUk   String
  contentEn   String
  rating      Int      @default(5)
  isPublished Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  @@map("testimonials")
}
